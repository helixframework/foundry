{$DASHBOARD_DOMAIN:localhost} {
  tls {$CADDY_TLS_MODE:internal}
  handle /api/* {
    reverse_proxy dashboard-api:8080
  }
  root * /srv/dashboard-web
  file_server
}

{$GITEA_DOMAIN:gitea.localhost} {
  tls {$CADDY_TLS_MODE:internal}
  reverse_proxy gitea:3000
}

{$TEAMCITY_DOMAIN:teamcity.localhost} {
  tls {$CADDY_TLS_MODE:internal}
  reverse_proxy teamcity-server:8111
}

{$NEXUS_DOMAIN:nexus.localhost} {
  tls {$CADDY_TLS_MODE:internal}
  reverse_proxy nexus:8081
}
