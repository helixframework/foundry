# Host user/group for file permissions
PUID=1000
PGID=1000

# Docker object names
STACK_NETWORK_NAME=selfhosted-cicd-net
POSTGRES_CONTAINER_NAME=cicd-postgres
HOMEPAGE_CONTAINER_NAME=cicd-homepage
GITEA_CONTAINER_NAME=gitea
TEAMCITY_SERVER_CONTAINER_NAME=teamcity-server
TEAMCITY_AGENT_CONTAINER_NAME=teamcity-agent-1
TEAMCITY_AGENT_NAME=teamcity-agent-1

# Exposed ports on host
POSTGRES_PORT=5432
HOMEPAGE_PORT=8080
GITEA_HTTP_PORT=3000
GITEA_SSH_PORT=2222
TEAMCITY_HTTP_PORT=8111

# PostgreSQL admin database (container bootstrap)
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=postgres_admin_password
POSTGRES_ADMIN_DB=postgres

# Application databases/users created by installer init SQL
GITEA_DB_NAME=gitea
GITEA_DB_USER=gitea
GITEA_DB_PASSWORD=gitea_password
TEAMCITY_DB_NAME=teamcity
TEAMCITY_DB_USER=teamcity
TEAMCITY_DB_PASSWORD=teamcity_password

# Public URL used by Gitea in links and clone URLs
# Change this to your host DNS/IP once deployed.
GITEA_ROOT_URL=http://localhost:3000/
